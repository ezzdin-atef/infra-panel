{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./crypto": {
      "types": "./src/crypto.ts",
      "default": "./dist/crypto.js"
    },
    "./jwt": {
      "types": "./src/jwt.ts",
      "default": "./dist/jwt.js"
    }
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "bcryptjs": "^2",
    "jsonwebtoken": "^9"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2",
    "@types/jsonwebtoken": "^9",
    "typescript": "^5"
  }
}
